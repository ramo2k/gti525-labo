			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Le statut HTTP est 200 (Succès)\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Le format est bien du JSON\", function () {",
							"    pm.response.to.be.json;",
							"});",
							"pm.test(\"Contient une FeatureCollection GeoJSON\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.type).to.eql(\"FeatureCollection\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
